model User {
  uid       Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  roleUid   Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role               Role              @relation(fields: [roleUid], references: [uid])
  clientsCreated     Client[]          @relation("ClientCreator")
  engagementsCreated AuditEngagement[] @relation("EngagementCreator")
  documentsUploaded  Document[]        @relation("DocumentUploader")
  documentLogs       DocumentLog[]     @relation("DocumentLogPerformer")
  risksCreated       Risk[]            @relation("RiskCreator")
  checklistAssigned  ChecklistAssignment[] @relation("ChecklistAssignee")
  checklistAssignedBy ChecklistAssignment[] @relation("ChecklistAssigner")
  tasksCreated       Task[]            @relation("TaskCreator")
  taskAssigned       TaskAssignment[]  @relation("TaskAssignee")
  taskAssignedBy     TaskAssignment[]  @relation("TaskAssigner")
  taskComments       TaskComment[]     @relation("TaskCommentAuthor")
  issuesCreated      Issue[]           @relation("IssueCreator")
  findingsCreated    Finding[]         @relation("FindingCreator")
  issueAssigned      IssueAssignment[] @relation("IssueAssignee")
  issueAssignedBy    IssueAssignment[] @relation("IssueAssigner")
  issueStatusChanges IssueStatusLog[]  @relation("IssueStatusChanger")

  @@index([roleUid])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}
