model Issue {
  uid                Int      @id @default(autoincrement())
  engagementUid      Int
  title              String
  description        String?
  severity           String   @default("MEDIUM")
  status             String   @default("OPEN")
  responsiblePerson  String?
  assignedClientUid  Int?
  createdByUid       Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  engagement     AuditEngagement   @relation(fields: [engagementUid], references: [uid], onDelete: Cascade)
  assignedClient Client?           @relation(fields: [assignedClientUid], references: [uid])
  createdBy      User              @relation("IssueCreator", fields: [createdByUid], references: [uid])
  findings       Finding[]
  assignments    IssueAssignment[]
  statusLogs     IssueStatusLog[]

  @@index([engagementUid, createdAt(sort: Desc)])
  @@index([status])
  @@index([engagementUid, status, createdAt(sort: Desc)])
  @@index([assignedClientUid])
  @@map("issues")
}
